{
  "workflowId": "xhs_submit_search",
  "observerSpec": {
    "requireAccessibility": false,
    "requireScreenshot": false,
    "requireRootDump": true
  },
  "targetFilter": {
    "anchorId": "search_submit",
    "selector": {
      "contentDescContains": "搜索",
      "clickable": true
    }
  },
  "operationPlan": {
    "kind": "tap",
    "backend": "root"
  },
  "anchorPolicy": {
    "preAnchor": {
      "packageName": "com.xingin.xhs",
      "mustContainTexts": ["deepseek v4"]
    },
    "postAnchor": {
      "packageName": "com.xingin.xhs",
      "mustContainContentDescs": ["笔记"]
    }
  },
  "timingPolicy": {
    "minDelayMs": 900,
    "maxDelayMs": 1800
  },
  "postObservePolicy": {
    "maxAttempts": 10,
    "pollIntervalMs": 500
  }
}
