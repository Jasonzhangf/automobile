{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowy.dev/protocol/control/log-entry.schema.json",
  "title": "LogEntry",
  "type": "object",
  "required": ["ts", "level", "event", "message"],
  "properties": {
    "ts": {"type": "string", "format": "date-time"},
    "level": {"type": "string", "enum": ["debug", "info", "warn", "error"]},
    "event": {"type": "string"},
    "requestId": {"type": "string"},
    "runId": {"type": "string"},
    "command": {"type": "string"},
    "message": {"type": "string"}
  }
}
