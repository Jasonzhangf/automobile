{
  "workflowId": "xhs_open_comment_expanded",
  "observerSpec": {
    "requireAccessibility": false,
    "requireScreenshot": false,
    "requireRootDump": true
  },
  "targetFilter": {
    "anchorId": "comment_entry",
    "selector": {
      "contentDescContains": "评论",
      "clickable": true
    }
  },
  "operationPlan": {
    "kind": "tap",
    "backend": "root"
  },
  "anchorPolicy": {
    "preAnchor": {
      "packageName": "com.xingin.xhs"
    },
    "postAnchor": {
      "packageName": "com.xingin.xhs",
      "mustContainContentDescs": ["评论"]
    }
  },
  "timingPolicy": {
    "minDelayMs": 800,
    "maxDelayMs": 1500
  },
  "postObservePolicy": {
    "maxAttempts": 8,
    "pollIntervalMs": 400
  }
}
