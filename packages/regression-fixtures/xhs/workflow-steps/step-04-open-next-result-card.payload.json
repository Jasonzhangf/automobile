{
  "workflowId": "xhs_open_next_result_card",
  "observerSpec": {
    "requireAccessibility": false,
    "requireScreenshot": true,
    "requireRootDump": true
  },
  "targetFilter": {
    "anchorId": "result_card",
    "selector": {
      "contentDescContains": "笔记",
      "longClickable": true
    }
  },
  "operationPlan": {
    "kind": "tap",
    "backend": "root"
  },
  "anchorPolicy": {
    "preAnchor": {
      "packageName": "com.xingin.xhs"
    },
    "postAnchor": {
      "packageName": "com.xingin.xhs",
      "mustContainContentDescs": ["赞"]
    }
  },
  "timingPolicy": {
    "minDelayMs": 1000,
    "maxDelayMs": 2000
  },
  "postObservePolicy": {
    "maxAttempts": 10,
    "pollIntervalMs": 500
  },
  "riskFlags": {
    "riskSensitive": true,
    "notes": ["XHS search result tap must use root backend only"]
  }
}
