{
  "workflowId": "xhs_input_keyword",
  "observerSpec": {
    "requireAccessibility": false,
    "requireScreenshot": false,
    "requireRootDump": true
  },
  "targetFilter": {
    "anchorId": "search_input",
    "selector": {
      "editable": true
    }
  },
  "operationPlan": {
    "kind": "input-text",
    "backend": "root",
    "payload": {
      "text": "露营装备"
    }
  },
  "anchorPolicy": {
    "preAnchor": {
      "packageName": "com.xingin.xhs"
    },
    "postAnchor": {
      "packageName": "com.xingin.xhs",
      "mustContainTexts": ["露营装备"]
    }
  },
  "timingPolicy": {
    "minDelayMs": 800,
    "maxDelayMs": 1500
  },
  "postObservePolicy": {
    "maxAttempts": 6,
    "pollIntervalMs": 300
  }
}
